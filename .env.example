# OPCare — eine einzige .env für den gesamten Docker-Stack.
#   cp .env.example .env  &&  docker compose up --build
# APP_KEY leer lassen — der App-Container erzeugt ihn beim ersten Start automatisch.
# Es gibt KEINE .env.dev/.env.prod: dieselbe Datei treibt Compose UND Laravel.

APP_NAME=OPCare
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8099
# Host-Port, unter dem die App erreichbar ist (nginx → 80 im Container).
APP_PORT=8099

APP_LOCALE=de
APP_FALLBACK_LOCALE=de
APP_FAKER_LOCALE=de_DE

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Datenbank (Postgres-Service im Compose-Netz) --------------------------------
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=opcare
DB_USERNAME=opcare
DB_PASSWORD=secret

# --- Sessions / Queue / Cache laufen über Redis (Horizon braucht Redis) ----------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Broadcasting / WebSockets (Reverb) ------------------------------------------
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=opcare
REVERB_APP_KEY=opcare-key
REVERB_APP_SECRET=opcare-secret
# Client-seitig (Browser verbindet auf den gemappten Host-Port):
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
# Server-seitig (Bindeadresse im Container):
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@opcare.local"
MAIL_FROM_NAME="${APP_NAME}"

# --- Spracherfassung (Whisper-MCP + Ollama) --------------------------------------
# Standard: Fake-Treiber, damit der Stack ohne externe Dienste läuft.
# Für echte Transkription auf false setzen und WHISPER_*/OLLAMA_* füllen.
SPEECH_FAKE=true
# WHISPER_URL=http://host.docker.internal:8000
# WHISPER_TOKEN=
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen3.5:latest

VITE_APP_NAME="${APP_NAME}"

# Bewohner-Dokumente/Fotos: 'media' (lokal, Default) oder 'minio' (self-hosted S3)
OPCARE_MEDIA_DISK=media
OPCARE_MEDIA_RETENTION_YEARS=10
MINIO_ACCESS_KEY=opcare
MINIO_SECRET_KEY=opcare-secret
MINIO_BUCKET=opcare-media
MINIO_ENDPOINT=http://minio:9000
MINIO_REGION=us-east-1
